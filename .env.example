# =============================================================================
# LangRAG - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env
#
# Environment file loading priority:
#   1. ENV_FILE env var (explicit path)
#   2. .env (production default)
#   3. .env.dev (development fallback)
#   4. System environment variables (Docker/containerized)
#
# To use a specific env file: ENV_FILE=/path/to/.env.custom

# =============================================================================
# REQUIRED: API Keys
# =============================================================================

# Beeper/Matrix Configuration (for WhatsApp message extraction)
BEEPER_HOMESERVER=https://matrix.beeper.com
BEEPER_EMAIL=
BEEPER_PASSWORD=
BEEPER_EXPORT_PASSWORD=
BEEPER_ACCESS_TOKEN=

# Beeper Recovery Code (for automated server-side key backup sync)
# Get from: password manager, iCloud Keychain, or Google Password Manager
# Generate new: Beeper app > Settings > Security > Reset Secure Storage
# Setup: python scripts/beeper_keys/setup_recovery_code.py
# Format: Base58 encoded (spaces allowed, will be stripped)
BEEPER_RECOVERY_CODE=

# LLM Provider Selection (openai, anthropic, gemini)
# Controls which provider is used for all LLM operations
LLM_PROVIDER=openai

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic API Key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Google Gemini API Key (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Decrypted Keys File Path
DECRYPTED_KEYS_FILE_PATH=/app/secrets/decrypted-keys.json

# =============================================================================
# OPTIONAL: Newsletter Delivery
# =============================================================================

# -----------------------------------------------------------------------------
# Email Provider Selection
# -----------------------------------------------------------------------------
# Choose: "gmail" or "sendgrid" (auto-detects if not set)
EMAIL_PROVIDER=gmail

# Default email recipient for newsletter notifications
# Used when send_email action is triggered without explicit recipients
DEFAULT_EMAIL_RECIPIENT=

# Application Base URL (used in email links)
# Set to your deployment URL (e.g., https://newsletter.yourdomain.com)
APP_BASE_URL=http://localhost

# -----------------------------------------------------------------------------
# Gmail SMTP Configuration (Recommended for personal use)
# -----------------------------------------------------------------------------
# Setup:
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an "App Password" for "Mail"
# 4. Use that 16-character password below (not your regular Gmail password!)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# -----------------------------------------------------------------------------
# SendGrid Configuration (For production/high-volume)
# -----------------------------------------------------------------------------
# Setup:
# 1. Create account at https://sendgrid.com
# 2. Verify sender email/domain
# 3. Generate API key
SENDGRID_API_KEY=
EMAIL_SENDER_ADDRESS=newsletter@yourdomain.com

# -----------------------------------------------------------------------------
# Substack Configuration
# -----------------------------------------------------------------------------
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=

# =============================================================================
# OPTIONAL: Observability & Monitoring
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Tracing (Langfuse)
# -----------------------------------------------------------------------------
# Langfuse provides LLM observability for cost tracking, latency monitoring,
# and quality evaluation. Includes fail-fast evaluation scoring.
#
# Access UI: http://localhost:3001
# Documentation: knowledge/observability/OBSERVABILITY_OVERVIEW.md

# Kill switch: set to false to disable tracing
LANGFUSE_ENABLED=true

# API credentials (get from Langfuse UI: Settings > API Keys > Create new key)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Host URL (use http://langfuse-server:3000 for Docker containers)
LANGFUSE_HOST=http://langfuse-server:3000

# =============================================================================
# SECURITY: REQUIRED SECRETS (Docker Compose will fail without these)
# =============================================================================
# Generate secure values with: openssl rand -base64 32
#
# WARNING: These have NO defaults. Docker Compose will error if not set.

# Langfuse authentication secrets
LANGFUSE_AUTH_SECRET=CHANGE_ME_RUN_openssl_rand_-base64_32
LANGFUSE_SALT=CHANGE_ME_RUN_openssl_rand_-base64_32

# Langfuse database credentials
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=CHANGE_ME_RUN_openssl_rand_-base64_32

# -----------------------------------------------------------------------------
# Application Logging (Loki + Grafana + Promtail)
# -----------------------------------------------------------------------------
# Structured JSON logging with Israel timezone, full-text search, and
# visualization. Logs link to Langfuse traces via trace_id.
#
# Access UIs:
# - Grafana: http://localhost:3002 (log visualization + pre-built dashboards)
# - Loki: http://localhost:3100 (log storage + query API)

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: "json" for production (Loki), "pretty" for development
LOG_FORMAT=json

# Service identifier in logs (used for filtering in Grafana)
SERVICE_NAME=langrag

# Environment tag in logs (development, staging, production)
ENVIRONMENT=development

# Grafana admin credentials (default: admin/admin, change on first login)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# LangSmith (Cloud Alternative to Langfuse)
# -----------------------------------------------------------------------------
# Optional: Use LangSmith cloud instead of self-hosted Langfuse
# https://smith.langchain.com

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langrag
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# OPTIONAL: Application Settings
# =============================================================================

# Backend Port
BACKEND_PORT=8000

# Frontend Port
FRONTEND_PORT=3000

# Docker User Mapping (prevents file permission issues)
# Set to your user ID and group ID to match host filesystem permissions
# Default: 1001:1001 (automatically detected)
# To find yours: run `id -u` and `id -g`
USER_ID=1001
GROUP_ID=1001

# Frontend API URL — MUST be empty string to avoid double /api/api/ prefix bug
# See CLAUDE.md "Frontend Build Pitfall" for details
REACT_APP_API_BASE_URL=

# Node Environment
NODE_ENV=development

# =============================================================================
# OPTIONAL: n8n Workflow Automation (LinkedIn Integration)
# =============================================================================

# n8n Basic Auth Credentials
N8N_USER=admin
N8N_PASSWORD=

# =============================================================================
# SLM (Small Language Model) Configuration - Message Pre-filtering
# =============================================================================
# Local SLM inference via Ollama for filtering low-quality messages
# before expensive LLM processing. Reduces API costs by 15-30%.

# Kill switch: set to false to disable SLM filtering entirely
SLM_ENABLED=false

# Ollama configuration
SLM_PROVIDER=ollama
SLM_BASE_URL=http://ollama:11434
SLM_MODEL=phi3:mini
SLM_FALLBACK_MODEL=gemma2:2b

# Classification tuning
SLM_CONFIDENCE_THRESHOLD=0.7
SLM_TEMPERATURE=0.1
SLM_MAX_TOKENS=50

# Performance settings
SLM_REQUEST_TIMEOUT_SECONDS=60
SLM_MAX_RETRIES=2
SLM_BATCH_SIZE=10

# Ollama container settings (Docker)
OLLAMA_PORT=11434
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=1

# =============================================================================
# Database Configuration
# =============================================================================

# MongoDB (primary database with vector search)
MONGODB_PORT=27017
MONGODB_DATABASE=langrag

# -----------------------------------------------------------------------------
# MongoDB-Only Migration Feature Flags
# -----------------------------------------------------------------------------
# These flags enable phased migration from file-based to MongoDB-only persistence.
# Set to true to enable rollback/backward compatibility modes.

# Generate output files (Phase 1 rollback)
# false = MongoDB-only, true = dual-write (MongoDB + files)
MONGODB_ENABLE_FILE_OUTPUTS=false

# Use file-based history loader (Phase 2 rollback)
# false = MongoDB queries, true = file system scanning
MONGODB_USE_FILE_BASED_HISTORY=false

# Use file-based extraction cache (Phase 3 rollback)
# false = MongoDB cache, true = file-based cache
MONGODB_ENABLE_FILE_CACHE=false

# Keep file path fields in state schemas (Phase 4 rollback)
# false = newsletter_id only, true = both newsletter_id and file paths
MONGODB_LEGACY_FILE_PATH_SUPPORT=false

# MongoDB-specific settings
MONGODB_EXTRACTION_CACHE_TTL_DAYS=30
MONGODB_NEWSLETTER_HISTORY_LIMIT=10
MONGODB_QUERY_TIMEOUT_MS=5000

# PostgreSQL (legacy - uncomment if needed)
# POSTGRES_USER=langrag
# POSTGRES_PASSWORD=langrag_dev_password
# POSTGRES_DB=langrag
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://langrag:langrag_dev_password@postgres:5432/langrag
