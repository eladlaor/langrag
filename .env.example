# =============================================================================
# LangRAG - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env
#
# Environment file loading priority:
#   1. ENV_FILE env var (explicit path)
#   2. .env (production default)
#   3. .env.dev (development fallback)
#   4. System environment variables (Docker/containerized)
#
# To use a specific env file: ENV_FILE=/path/to/.env.custom

# =============================================================================
# REQUIRED: API Keys
# =============================================================================

# Beeper/Matrix Configuration (for WhatsApp message extraction)
BEEPER_HOMESERVER=https://matrix.beeper.com
BEEPER_EMAIL=
BEEPER_PASSWORD=
BEEPER_EXPORT_PASSWORD=
BEEPER_ACCESS_TOKEN=

# Beeper Recovery Code (for automated server-side key backup sync)
# Get from: password manager, iCloud Keychain, or Google Password Manager
# Generate new: Beeper app > Settings > Security > Reset Secure Storage
# Setup: python scripts/beeper_keys/setup_recovery_code.py
# Format: Base58 encoded (spaces allowed, will be stripped)
BEEPER_RECOVERY_CODE=

# LLM Provider Selection (openai, anthropic, gemini)
# Controls which provider is used for all LLM operations
LLM_PROVIDER=openai

# -----------------------------------------------------------------------------
# LLM Model Configuration (per-provider)
# -----------------------------------------------------------------------------
# Override default models for each provider. Only the active provider's models are used.
# Env prefix: LLM_ (e.g., LLM_OPENAI_DEFAULT_MODEL)

# OpenAI models
LLM_OPENAI_DEFAULT_MODEL=gpt-4.1
LLM_OPENAI_MINI_MODEL=gpt-4.1-mini
LLM_OPENAI_RANKING_MODEL=gpt-4o

# Anthropic models
LLM_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_ANTHROPIC_MINI_MODEL=claude-haiku-4-5-20251001
LLM_ANTHROPIC_RANKING_MODEL=claude-sonnet-4-20250514

# Gemini models
LLM_GEMINI_DEFAULT_MODEL=gemini-2.5-flash
LLM_GEMINI_MINI_MODEL=gemini-2.5-flash
LLM_GEMINI_RANKING_MODEL=gemini-2.5-flash

# OpenAI API Key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Anthropic API Key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Google Gemini API Key (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=

# Decrypted Keys File Path
DECRYPTED_KEYS_FILE_PATH=/app/secrets/decrypted-keys.json

# =============================================================================
# OPTIONAL: Newsletter Delivery
# =============================================================================

# -----------------------------------------------------------------------------
# Email Provider Selection
# -----------------------------------------------------------------------------
# Choose: "gmail" or "sendgrid" (auto-detects if not set)
EMAIL_PROVIDER=gmail

# Default email recipient for newsletter notifications
# Used when send_email action is triggered without explicit recipients
DEFAULT_EMAIL_RECIPIENT=

# Application Base URL (used in email links)
# Set to your deployment URL (e.g., https://newsletter.yourdomain.com)
APP_BASE_URL=http://localhost

# -----------------------------------------------------------------------------
# Gmail SMTP Configuration (Recommended for personal use)
# -----------------------------------------------------------------------------
# Setup:
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an "App Password" for "Mail"
# 4. Use that 16-character password below (not your regular Gmail password!)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# -----------------------------------------------------------------------------
# SendGrid Configuration (For production/high-volume)
# -----------------------------------------------------------------------------
# Setup:
# 1. Create account at https://sendgrid.com
# 2. Verify sender email/domain
# 3. Generate API key
SENDGRID_API_KEY=
EMAIL_SENDER_ADDRESS=newsletter@yourdomain.com

# -----------------------------------------------------------------------------
# Substack Configuration
# -----------------------------------------------------------------------------
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=

# =============================================================================
# OPTIONAL: Observability & Monitoring
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Tracing (Langfuse)
# -----------------------------------------------------------------------------
# Langfuse provides LLM observability for cost tracking, latency monitoring,
# and quality evaluation. Includes fail-fast evaluation scoring.
#
# Access UI: http://localhost:3001
# Documentation: knowledge/observability/OBSERVABILITY_OVERVIEW.md

# Kill switch: set to false to disable tracing
LANGFUSE_ENABLED=true

# API credentials (get from Langfuse UI: Settings > API Keys > Create new key)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Host URL (use http://langfuse-server:3000 for Docker containers)
LANGFUSE_HOST=http://langfuse-server:3000

# =============================================================================
# SECURITY: REQUIRED SECRETS (Docker Compose will fail without these)
# =============================================================================
# Generate secure values with: openssl rand -base64 32
#
# WARNING: These have NO defaults. Docker Compose will error if not set.

# Langfuse authentication secrets
LANGFUSE_AUTH_SECRET=CHANGE_ME_RUN_openssl_rand_-base64_32
LANGFUSE_SALT=CHANGE_ME_RUN_openssl_rand_-base64_32

# Langfuse database credentials
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=CHANGE_ME_RUN_openssl_rand_-base64_32

# -----------------------------------------------------------------------------
# Application Logging (Loki + Grafana + Promtail)
# -----------------------------------------------------------------------------
# Structured JSON logging with Israel timezone, full-text search, and
# visualization. Logs link to Langfuse traces via trace_id.
#
# Access UIs:
# - Grafana: http://localhost:3002 (log visualization + pre-built dashboards)
# - Loki: http://localhost:3100 (log storage + query API)

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: "json" for production (Loki), "pretty" for development
LOG_FORMAT=json

# Service identifier in logs (used for filtering in Grafana)
SERVICE_NAME=langrag

# Environment tag in logs (development, staging, production)
ENVIRONMENT=development

# Grafana admin credentials (default: admin/admin, change on first login)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# LangSmith (Cloud Alternative to Langfuse)
# -----------------------------------------------------------------------------
# Optional: Use LangSmith cloud instead of self-hosted Langfuse
# https://smith.langchain.com

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langrag
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# OPTIONAL: Application Settings
# =============================================================================

# Backend Port
BACKEND_PORT=8000

# Frontend Port
FRONTEND_PORT=3000

# Docker User Mapping (prevents file permission issues)
# Set to your user ID and group ID to match host filesystem permissions
# Default: 1001:1001 (automatically detected)
# To find yours: run `id -u` and `id -g`
USER_ID=1001
GROUP_ID=1001

# Frontend API URL — MUST be empty string to avoid double /api/api/ prefix bug
# See CLAUDE.md "Frontend Build Pitfall" for details
REACT_APP_API_BASE_URL=

# Node Environment
NODE_ENV=development

# =============================================================================
# OPTIONAL: n8n Workflow Automation (LinkedIn Integration)
# =============================================================================

# n8n Basic Auth Credentials
N8N_USER=admin
N8N_PASSWORD=

# =============================================================================
# SLM Semantic Enrichment Configuration
# =============================================================================
# In-process DeBERTa-v3 multi-label classifier (HuggingFace) that tags each
# message with 15 semantic labels before discussion ranking. Runs locally via
# PyTorch/transformers (no external service); model auto-downloaded from HF Hub
# on first use. Disabled by default; when off the enrichment node is a no-op.

# Master toggle: set to true to activate semantic enrichment
SLM_ENRICHMENT_ENABLED=false

# HuggingFace model for multi-label enrichment
SLM_ENRICHMENT_MODEL_NAME=eladlaor/chat-message-tagger-deberta-v3

# Inference settings
SLM_ENRICHMENT_BATCH_SIZE=32
SLM_ENRICHMENT_MAX_LENGTH=256

# =============================================================================
# Vision (Image Understanding) Configuration
# =============================================================================
# Vision LLM for describing images extracted from WhatsApp messages.
# Requires enable_image_extraction=true in API requests to activate.

# Master toggle: set to true to enable image extraction and vision description
VISION_ENABLED=false

# Vision LLM settings
VISION_PROVIDER=openai
VISION_MODEL=gpt-4.1-mini
VISION_TEMPERATURE=0.2
VISION_DESCRIPTION_MAX_TOKENS=300

# Image download settings
VISION_MAX_IMAGES_PER_CHAT=50
VISION_MAX_IMAGE_SIZE_BYTES=10485760
VISION_DOWNLOAD_TIMEOUT_SECONDS=30
VISION_DOWNLOAD_CONCURRENCY=5

# Description scope: "all" describes every image, "featured_only" only images in top discussions
VISION_DESCRIBE_SCOPE=all

# Cache TTL for vision descriptions (days)
VISION_CACHE_TTL_DAYS=30

# =============================================================================
# Database Configuration
# =============================================================================

# MongoDB (primary database with vector search)
MONGODB_PORT=27017
MONGODB_DATABASE=langrag

# -----------------------------------------------------------------------------
# MongoDB-Only Migration Feature Flags
# -----------------------------------------------------------------------------
# These flags enable phased migration from file-based to MongoDB-only persistence.
# Set to true to enable rollback/backward compatibility modes.

# Generate output files (Phase 1 rollback)
# false = MongoDB-only, true = dual-write (MongoDB + files)
MONGODB_ENABLE_FILE_OUTPUTS=false

# Use file-based history loader (Phase 2 rollback)
# false = MongoDB queries, true = file system scanning
MONGODB_USE_FILE_BASED_HISTORY=false

# Use file-based extraction cache (Phase 3 rollback)
# false = MongoDB cache, true = file-based cache
MONGODB_ENABLE_FILE_CACHE=false

# Keep file path fields in state schemas (Phase 4 rollback)
# false = newsletter_id only, true = both newsletter_id and file paths
MONGODB_LEGACY_FILE_PATH_SUPPORT=false

# MongoDB-specific settings
MONGODB_EXTRACTION_CACHE_TTL_DAYS=30
MONGODB_NEWSLETTER_HISTORY_LIMIT=10
MONGODB_QUERY_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# LangGraph Checkpointer (MongoDB-backed)
# -----------------------------------------------------------------------------
# TTL (seconds) for checkpoint documents. Bounds the otherwise-unbounded growth of
# the `checkpoints` + `checkpoint_writes` collections. Default 7 days (604800).
#
# SAFETY: MUST stay well above the longest legitimate paused HITL run, or a paused
# human-in-the-loop run could be reaped mid-pause and become unresumable. Keep
# CHECKPOINTER_TTL_SECONDS >> (hitl_selection_timeout_minutes * 60). If HITL can pause
# for a long time, raise this (e.g. 2592000 = 30 days) rather than lower it.
CHECKPOINTER_TTL_SECONDS=604800

# PostgreSQL (legacy - uncomment if needed)
# POSTGRES_USER=langrag
# POSTGRES_PASSWORD=langrag_dev_password
# POSTGRES_DB=langrag
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://langrag:langrag_dev_password@postgres:5432/langrag

# ============================================================================
# RAG (Retrieval-Augmented Generation) - Podcast Conversations
# ============================================================================

# Transcription provider: "openai" (Whisper API) or "local" (Docker sidecar)
RAG_TRANSCRIPTION_PROVIDER=openai
RAG_WHISPER_MODEL=whisper-1

# Retrieval parameters
RAG_VECTOR_SEARCH_TOP_K=20
RAG_RERANK_TOP_K=5
RAG_MIN_SIMILARITY_SCORE=0.7
RAG_MAX_CONVERSATION_HISTORY=10

# Chunking parameters
RAG_PODCAST_CHUNK_SIZE=1000
RAG_PODCAST_CHUNK_OVERLAP=200

# Generation LLM (follows multi-provider pattern)
RAG_LLM_PROVIDER=openai
RAG_LLM_MODEL=gpt-4.1

# ============================================================================
# DeepEval - RAG Quality Evaluation (Optional)
# ============================================================================

# Enable background quality evaluation after each RAG response
DEEPEVAL_ENABLED=false
DEEPEVAL_METRICS=["faithfulness", "answer_relevancy", "hallucination"]
DEEPEVAL_SAMPLING_RATE=1.0
DEEPEVAL_FAITHFULNESS_THRESHOLD=0.7
DEEPEVAL_ANSWER_RELEVANCY_THRESHOLD=0.7
DEEPEVAL_HALLUCINATION_THRESHOLD=0.5
DEEPEVAL_EVAL_MODEL=gpt-4.1-mini
DEEPEVAL_EVALUATION_TIMEOUT_SECONDS=120
DEEPEVAL_RESULTS_TTL_DAYS=90

# ============================================================================
# Agentic Chatbot (Optional)
# ============================================================================

# Mounts /api/agent/* (tool-calling chat) and /api/users/me/agent-keys
# (cookie-gated key minting). When false, none of those routes are mounted.
AGENT_ENABLED=true
# Tool-calling loop model and the memory extractor/summarizer model.
AGENT_AGENT_MODEL=claude-sonnet-4-6
AGENT_MEMORY_MODEL=claude-opus-4-7
# Hard ceiling on tool invocations within a single agent turn.
AGENT_MAX_TOOL_CALLS_PER_TURN=12
# Compress conversation history once it exceeds this many messages.
AGENT_SUMMARIZE_THRESHOLD=30
# Long-term memories injected into the agent prompt per turn.
AGENT_MEMORY_TOP_K=6

# ============================================================================
# API / Rate limiting
# ============================================================================
# Shared storage backend for rate-limit counters. Leave EMPTY for the default
# in-memory store, which is correct for the single-worker deployment (the
# Dockerfile runs one uvicorn process). If you ever run multiple uvicorn workers
# or app replicas, set this to a shared store (e.g. redis://redis:6379) or each
# process keeps its own counter and the effective limit becomes N× configured.
API_RATE_LIMIT_STORAGE_URI=

# ============================================================================
# UI Login Gate (per-user accounts + Fernet session cookie)
# ============================================================================
# Gates the entire UI behind per-user email+password accounts. When enabled,
# LANGRAG_LOGIN_SESSION_KEY is REQUIRED or the app refuses to start (fail-fast
# in the lifespan startup).
#
# Rotating LANGRAG_LOGIN_SESSION_KEY is the revocation mechanism: rotating it
# immediately voids every outstanding session cookie.

# Set to false ONLY for local dev to disable the gate; MUST stay true in production.
LANGRAG_LOGIN_ENABLED=true

# DEPRECATED and no longer used: per-user accounts replaced the single shared
# password. Safe to remove. Retained here only so old deployments that still
# export it do not break; it is NOT required at startup.
LANGRAG_LOGIN_PASSWORD=

# urlsafe-base64 32-byte Fernet key signing+encrypting session cookies.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LANGRAG_LOGIN_SESSION_KEY=

# Session cookie lifetime in minutes (default 12h). Fernet enforces this server-side on decrypt.
LANGRAG_LOGIN_SESSION_TTL_MINUTES=720

# Secure flag on the cookie. Keep true behind Cloudflare Flexible SSL (browser sees HTTPS).
LANGRAG_LOGIN_COOKIE_SECURE=true

# SameSite policy: lax | strict | none.
LANGRAG_LOGIN_COOKIE_SAMESITE=lax

# ---------------------------------------------------------------------------
# Self-signup + Google OAuth
# ---------------------------------------------------------------------------
# Self-serve signup is gated by an email allowlist. A non-allowlisted user is
# told plainly they are not on the allowlist and offered a contact form. A
# freshly self-signed-up user is always VIEWER with no communities.

# Allow self-serve signup (email+password and Google). Set false to disable.
LANGRAG_SIGNUP_ENABLED=true

# Emails permitted to self-register. JSON array (preferred) or CSV. Compared
# after normalization (lowercase + trim).
LANGRAG_SIGNUP_ALLOWLIST=["alice@example.com","bob@example.com"]

# Secret signing the transient Starlette session used by Authlib for the OAuth
# state+nonce round-trip. Required when Google is enabled. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
LANGRAG_SIGNUP_OAUTH_STATE_SECRET=

# Enable 'Sign in with Google'. The OAuth endpoints are wired in a later slice;
# keep false until a Google client is registered.
LANGRAG_GOOGLE_ENABLED=true

# Google OAuth web-application client id + secret (deploy-env only).
LANGRAG_GOOGLE_CLIENT_ID=
LANGRAG_GOOGLE_CLIENT_SECRET=

# Authorized redirect URI registered in the Google Cloud console.
LANGRAG_GOOGLE_REDIRECT_URI=https://langrag.ai/api/auth/google/callback

# =============================================================================
# MCP server (production profile)
# =============================================================================
# The mcp-server compose service is gated behind the `production` profile and is
# brought up with `docker compose --profile production up -d mcp-server`. It runs
# the FastMCP SSE transport behind nginx on mcp.langrag.ai.

# REQUIRED for `--profile production`: opaque bearer token the MCP HTTP transport
# validates on every request. The server refuses to start (exit 2) without it,
# and compose fails at parse time (:? form) if unset. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
RAG_MCP_API_KEY=

# Host publish port for the MCP server (container always listens on 8765).
MCP_PORT=8765

# Public tool surface toggle. true (production default on mcp.langrag.ai):
# register ONLY search_podcasts / list_podcasts; rag_query (owner-paid server-
# side generation + prompt-injection surface) is never registered. Set false
# ONLY for a trusted internal MCP deployment.
RAG_MCP_PUBLIC_MODE=true

# Host header allowlist for the HTTP/SSE MCP transport (MCP SDK DNS-rebinding
# guard). The SDK default is localhost-only, so a request forwarded by nginx/
# Cloudflare with Host: mcp.langrag.ai is 421'd after auth. Comma-separated hosts
# to allow (e.g. mcp.langrag.ai). EMPTY disables the guard entirely, which is safe
# when nginx is the sole ingress and pins the vhost to this upstream.
RAG_MCP_ALLOWED_HOSTS=

# -----------------------------------------------------------------------------
# Public podcast-MCP consumer key self-service (langrag.ai/podcasts)
# -----------------------------------------------------------------------------
# External AI engineers request a PODCAST_QUERY-scoped key via an email-verified
# flow. All values below have sane defaults in config.py; override per-env.
# MCP SSE endpoint returned to a consumer on successful verify (added to their
# MCP client with the minted key as a bearer token).
RAG_MCP_PUBLIC_URL=https://mcp.langrag.ai/sse
# Base URL of the issuance page; the verification email links here as ?token=<T>.
RAG_PODCAST_CONSUMER_VERIFY_BASE_URL=https://langrag.ai/podcasts
# Single-use verification token lifetime (minutes) before it 410s on verify.
RAG_PODCAST_CONSUMER_TOKEN_TTL_MINUTES=45
# Per-email request-key cap in a rolling 24h window (over it: still 202, no send).
RAG_PODCAST_CONSUMER_MAX_REQUESTS_PER_EMAIL_PER_DAY=3

# -----------------------------------------------------------------------------
# Production Langfuse (remote box)
# -----------------------------------------------------------------------------
# In production, Langfuse runs on a SEPARATE small box (see the deploy runbook
# knowledge/deployment/MCP_AND_LANGFUSE_PROD_ENABLEMENT.md), NOT co-located on
# the 4GB app box. When using docker-compose.langfuse-remote.yml, set the
# LANGFUSE_HOST above to the remote box's Hetzner private-net URL, e.g.:
#   LANGFUSE_HOST=http://<langfuse-private-ip>:3000
# LANGFUSE_ENABLED / LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY are defined in the
# "LLM Tracing (Langfuse)" section above and are reused as-is.
